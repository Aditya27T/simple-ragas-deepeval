# ============================================================
# Environment Variables — Project 1 LLM Evaluation System
# Salin file ini menjadi .env lalu isi nilai yang sesuai
# JANGAN commit file .env ke GitHub!
# ============================================================

# ----------------------------------------------------------
# OpenRouter (digunakan untuk semua model)
# Daftar & dapatkan API key di: https://openrouter.ai/keys
# ----------------------------------------------------------
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ----------------------------------------------------------
# Model IDs di OpenRouter
# Cek ID terbaru di: https://openrouter.ai/models
# ----------------------------------------------------------
MODEL_DEEPSEEK_FLASH=deepseek/deepseek-chat-v3-5k
MODEL_DEEPSEEK_PRO=deepseek/deepseek-r1
MODEL_MINIMAX=minimax/minimax-01
MODEL_GEMMA=google/gemma-2-27b-it
MODEL_LLAMA=meta-llama/llama-3.1-8b-instruct

# ----------------------------------------------------------
# Judge Model untuk LLM-as-Judge (RAGAS & DeepEval)
# Gunakan model yang powerful untuk evaluasi
# ----------------------------------------------------------
JUDGE_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# Slack Alerting
# Buat webhook di: https://api.slack.com/messaging/webhooks
# ----------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#llm-eval-alerts

# ----------------------------------------------------------
# Konfigurasi Evaluasi
# ----------------------------------------------------------
# Threshold untuk deteksi regresi (dalam desimal, bukan %)
WARNING_THRESHOLD=0.03
CRITICAL_THRESHOLD=0.08

# Jumlah query yang diproses sekaligus (async batch)
BATCH_SIZE=5

# Retry jika request gagal
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2

# ----------------------------------------------------------
# Path Dataset
# ----------------------------------------------------------
DATASET_PATH=../dataset_maja_ai.xlsx

# ----------------------------------------------------------
# DeepEval Config
# ----------------------------------------------------------
DEEPEVAL_TELEMETRY_OPT_OUT=YES

# --- TUGAS 2: PENGATURAN MODEL YANG DIUJI ---
# Hapus tanda pagar (#) dan sesuaikan jika Anda menggunakan API langsung (DeepSeek / Minimax)
# Jika dikosongkan, otomatis akan menggunakan OpenRouter (seperti di bawah)

# TEST_BASE_URL=https://api.deepseek.com/v1
# TEST_API_KEY=sk-deepseek-xxx
# TEST_MODEL=deepseek-chat

# TEST_BASE_URL=https://api.minimax.chat/v1
# TEST_API_KEY=sk-minimax-xxx
# TEST_MODEL=abab6.5-chat

# --- TUGAS 3: PENGATURAN JURI EVALUASI (JUDGE) ---
# Sangat disarankan juri tetap menggunakan OpenRouter (Claude / GPT-4o) untuk akurasi terbaik
OPENROUTER_API_KEY=sk-or-v1-xxxxxx
JUDGE_MODEL=anthropic/claude-3.5-sonnet
